        "header": [{"key":"Content-Type","value":"application/json"}],
        "body": {"mode":"raw","raw":"{\n  \"ticket_id\": \"TBUY1\",\n  \"event_id\": \"E001\",\n  \"seat_id\": \"SEAT-S001-04\",\n  \"reserved\": \"N\",\n  \"purchased_by\": \"U1\"\n}"},
        "url": { "raw": "http://localhost:3000/api/tickets", "protocol": "http", "host": ["localhost"], "port": "3000", "path": ["api","tickets"] }
